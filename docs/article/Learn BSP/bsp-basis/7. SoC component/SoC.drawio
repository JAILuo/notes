  <diagram id="EA89g4_LvttixXyR0dsE" name="第 7 页">
    <mxGraphModel dx="1128" dy="651" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="qWVq7Pqy6OZzOo4xPE85-1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#90A4AE;strokeWidth=2.5;dashed=1;dashPattern=6 6;align=right;verticalAlign=bottom;spacing=15;fontColor=#78909C;fontSize=14;fontStyle=1;arcSize=2;fontFamily=Comic Sans MS;" value="SoC (System-on-Chip) 芯片整体封装边界 (Package)" vertex="1">
          <mxGeometry height="608" width="1130" x="170" y="257" as="geometry" />
        </mxCell>
        <mxCell id="qWVq7Pqy6OZzOo4xPE85-2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#78909C;strokeWidth=1.5;dashed=1;dashPattern=4 4;align=left;verticalAlign=bottom;spacing=15;fontColor=#546E7A;fontSize=13;fontStyle=1;arcSize=2;fontFamily=Comic Sans MS;" value="SoC Die (硅晶圆主芯片) 物理边界" vertex="1">
          <mxGeometry height="435" width="1090" x="190" y="395" as="geometry" />
        </mxCell>
        <mxCell id="qWVq7Pqy6OZzOo4xPE85-3" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 22px; color: rgb(44, 62, 80);&quot;&gt;片上系统 (SoC) 内部 IP 核与高级封装架构&lt;/b&gt;" vertex="1">
          <mxGeometry height="60" width="700" x="475" y="197" as="geometry" />
        </mxCell>
        <mxCell id="qWVq7Pqy6OZzOo4xPE85-4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#FF8F00;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=12;spacingRight=12;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #E65100;&quot;&gt;LPDDR 运行内存 (SiP / PoP / 先进封装集成)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #FFE082; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #5D4037;&quot;&gt;采用封装级集成 (SiP/PoP)，作为独立 Die 封装于芯片内 (单片集成/eDRAM除外)。&lt;br&gt;物理上不属于 SoC 逻辑晶圆，通过高密度晶圆级微引脚与底层的存储物理层接口 (PHY) 实现对接。&lt;/span&gt;" vertex="1">
          <mxGeometry height="80" width="1050" x="210" y="285" as="geometry" />
        </mxCell>
        <mxCell id="qWVq7Pqy6OZzOo4xPE85-5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#37474F;strokeColor=none;fontColor=#ECEFF1;shadow=1;arcSize=10;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size:20px;letter-spacing:10px;&quot;&gt;片 内 互 联 总 线 &amp;nbsp; (System Interconnect Bus)&lt;/b&gt;" vertex="1">
          <mxGeometry height="45" width="1050" x="210" y="575" as="geometry" />
        </mxCell>
        <mxCell id="qWVq7Pqy6OZzOo4xPE85-6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0288D1;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #01579B;&quot;&gt;内存控制器&lt;br&gt;(DMC+PHY)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #81D4FA; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #455A64;&quot;&gt;作为 AXI Slave 接收片内总线请求，转换为 DDR 物理时序协议对接封装内 DRAM。&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="150" x="210" y="425" as="geometry" />
        </mxCell>
        <mxCell id="qWVq7Pqy6OZzOo4xPE85-7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0288D1;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #01579B;&quot;&gt;应用处理器 (AP /&lt;br&gt;CPU)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #81D4FA; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #455A64;&quot;&gt;多核高性能中央处理器，负责运行通用操作系统 (HLOS) 及核心事务调度。&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="150" x="390" y="425" as="geometry" />
        </mxCell>
        <mxCell id="qWVq7Pqy6OZzOo4xPE85-8" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0288D1;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #01579B;&quot;&gt;图形处理器 (GPU)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #81D4FA; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #455A64;&quot;&gt;负责屏幕图形物理渲染、UI界面深度合成以及通用 GPU 硬件并行计算加速。&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="150" x="570" y="425" as="geometry" />
        </mxCell>
        <mxCell id="qWVq7Pqy6OZzOo4xPE85-9" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0288D1;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #01579B;&quot;&gt;数字信号处理器&lt;br&gt;(DSP)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #81D4FA; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #455A64;&quot;&gt;专门用于高效处理低延迟语音、音频编解码以及超低功耗传感器流监听。&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="150" x="750" y="425" as="geometry" />
        </mxCell>
        <mxCell id="qWVq7Pqy6OZzOo4xPE85-10" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0288D1;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #01579B;&quot;&gt;图像信号处理器&lt;br&gt;(ISP)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #81D4FA; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #455A64;&quot;&gt;硬件级处理相机传感器传回的原始 RAW 流，执行实时降噪、HDR 与色彩重构。&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="150" x="390" y="655" as="geometry" />
        </mxCell>
        <mxCell id="qWVq7Pqy6OZzOo4xPE85-11" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#388E3C;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #1B5E20;&quot;&gt;蓝牙 / WiFi 协议栈&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #A5D6A7; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #2E7D32;&quot;&gt;处理无线连接的基带与协议层逻辑，对接外部射频前端前端。&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="150" x="930" y="425" as="geometry" />
        </mxCell>
        <mxCell id="qWVq7Pqy6OZzOo4xPE85-12" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0288D1;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: rgb(1, 87, 155);&quot;&gt;神经网络单元 (NPU) / AI加速器&lt;/b&gt;&lt;hr style=&quot;border: 1px solid rgb(129, 212, 250); margin: 4px 0px;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: rgb(69, 90, 100);&quot;&gt;负责CNN/Transformer的大规模矩阵乘加与卷积运算加速&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="150" x="210" y="655" as="geometry" />
        </mxCell>
        <mxCell id="qWVq7Pqy6OZzOo4xPE85-14" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00897B;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #004D40;&quot;&gt;电源控制逻辑&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #80CBC4; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #37474F;&quot;&gt;SoC 内部的分区电源动态管理逻辑 (DVFS)，对接外部 PMIC 芯片。&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="150" x="570" y="655" as="geometry" />
        </mxCell>
        <mxCell id="qWVq7Pqy6OZzOo4xPE85-15" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00897B;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #004D40;&quot;&gt;安全处理单元 (SPU)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #80CBC4; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #37474F;&quot;&gt;硬件物理隔离安全岛，负责系统底层国密/RSA加解密及安全启动。&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="150" x="750" y="655" as="geometry" />
        </mxCell>
        <mxCell id="qWVq7Pqy6OZzOo4xPE85-16" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00897B;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #004D40;&quot;&gt;SensorHub&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #80CBC4; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #37474F;&quot;&gt;全天候不间断工作的微控制核心，独立聚合各类低速传感器上下文。&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="150" x="930" y="655" as="geometry" />
        </mxCell>
        <mxCell id="qWVq7Pqy6OZzOo4xPE85-17" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00897B;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #004D40;&quot;&gt;通用外设总线主控&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #80CBC4; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #37474F;&quot;&gt;包含 I²C, SPI, UART, GPIO 等低速通信协议的硬件控制器 PHY 层。&lt;/span&gt;" vertex="1">
