  <diagram id="XrumGw3OUpGZ98oQuA85" name="第 4 页">
    <mxGraphModel dx="1128" dy="651" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="2lWPLS22yn9Cp41EMGf9-1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#B0BEC5;strokeWidth=2;dashed=1;dashPattern=8 8;align=right;verticalAlign=bottom;spacing=15;fontColor=#90A4AE;fontSize=14;fontStyle=1;arcSize=2;fontFamily=Comic Sans MS;" value="SoC (System-on-Chip) 芯片/封装物理边界" vertex="1">
          <mxGeometry height="610" width="1160" x="150" y="126" as="geometry" />
        </mxCell>
        <mxCell id="2lWPLS22yn9Cp41EMGf9-2" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 22px; color: rgb(44, 62, 80);&quot;&gt;片上系统 (SoC) 内部 IP 核架构&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size: 13px; color: rgb(127, 140, 141);&quot;&gt;展示 SoC 内部核心通过内部互联总线通信的拓扑。&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;font-size: 13px; color: rgb(127, 140, 141);&quot;&gt;DDR 采用封装级集成(SiP)独立托管，不直接挂载在系统通用总线上。&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="700" x="380" y="135" as="geometry" />
        </mxCell>
        <mxCell id="2lWPLS22yn9Cp41EMGf9-3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#FF8F00;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=12;spacingRight=12;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: rgb(230, 81, 0);&quot;&gt;LPDDR 运行内存 (SiP / PoP / 先进封装集成)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid rgb(255, 224, 130); margin: 4px 0px;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: rgb(93, 64, 55);&quot;&gt;一般来说，DRAM物理上是独立的存储晶圆，不属于 SoC 逻辑晶圆（单片集成/eDRAM除外）。&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;font-size: 11px; color: rgb(93, 64, 55);&quot;&gt;SoC 内部通过专用内存控制器和 PHY 与封装内的 DRAM 通信，DRAM 不直接挂载在 SoC 内部的通用互联总线（如 AXI/CHI）上。&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="75" width="1080" x="190" y="230" as="geometry" />
        </mxCell>
        <mxCell id="2lWPLS22yn9Cp41EMGf9-4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#37474F;strokeColor=none;fontColor=#ECEFF1;shadow=1;arcSize=10;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size:20px;letter-spacing:10px;&quot;&gt;内 部 互 联 总 线 &amp;nbsp; (System Interconnect Bus)&lt;/b&gt;" vertex="1">
          <mxGeometry height="45" width="1080" x="190" y="510" as="geometry" />
        </mxCell>
        <mxCell id="2lWPLS22yn9Cp41EMGf9-5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0288D1;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #01579B;&quot;&gt;应用处理器 (AP / CPU)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #81D4FA; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #455A64;&quot;&gt;多核高性能中央处理器，负责运行操作系统 (HLOS) 及核心调度。&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="170" x="190" y="360" as="geometry" />
        </mxCell>
        <mxCell id="2lWPLS22yn9Cp41EMGf9-6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0288D1;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #01579B;&quot;&gt;图形处理器 (GPU)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #81D4FA; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #455A64;&quot;&gt;负责屏幕图形渲染、UI界面合成以及 GPU 硬件计算加速。&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="170" x="370" y="360" as="geometry" />
        </mxCell>
        <mxCell id="2lWPLS22yn9Cp41EMGf9-7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0288D1;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #01579B;&quot;&gt;数字信号处理器 (DSP)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #81D4FA; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #455A64;&quot;&gt;专门用于高效处理语音、音频编解码以及超低功耗待机监听。&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="170" x="550" y="360" as="geometry" />
        </mxCell>
        <mxCell id="2lWPLS22yn9Cp41EMGf9-8" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0288D1;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #01579B;&quot;&gt;图像信号处理器 (ISP)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #81D4FA; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #455A64;&quot;&gt;硬件级处理相机传感器传回的原始数据，执行降噪、对焦与色彩。&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="170" x="730" y="360" as="geometry" />
        </mxCell>
        <mxCell id="2lWPLS22yn9Cp41EMGf9-9" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#388E3C;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #1B5E20;&quot;&gt;蓝牙 / WiFi 协议栈&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #A5D6A7; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #2E7D32;&quot;&gt;处理无线连接的基带与协议层逻辑，对接外部射频前端前端。&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="170" x="910" y="360" as="geometry" />
        </mxCell>
        <mxCell id="2lWPLS22yn9Cp41EMGf9-10" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#388E3C;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #1B5E20;&quot;&gt;蜂窝基带 (Modem)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #A5D6A7; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #2E7D32;&quot;&gt;处理 4G/5G 移动网络通信协议计算，包含专用数字信号处理器。&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="170" x="1090" y="360" as="geometry" />
        </mxCell>
        <mxCell id="2lWPLS22yn9Cp41EMGf9-11" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0288D1;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #01579B;&quot;&gt;神经网络单元 (NPU)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #81D4FA; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #455A64;&quot;&gt;专为端侧 AI 设计的加速器，高效执行深度学习中的矩阵和矢量运算。&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="170" x="190" y="590" as="geometry" />
        </mxCell>
        <mxCell id="2lWPLS22yn9Cp41EMGf9-12" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0288D1;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #01579B;&quot;&gt;张量处理器 (TPU)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #81D4FA; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #455A64;&quot;&gt;执行更高级的大规模 AI 张量运算，部分SoC中由高阶 DSP 或 NPU 复用。&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="170" x="370" y="590" as="geometry" />
        </mxCell>
        <mxCell id="2lWPLS22yn9Cp41EMGf9-13" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00897B;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #004D40;&quot;&gt;电源控制逻辑&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #80CBC4; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #37474F;&quot;&gt;SoC 内部的分区电源动态管理逻辑 (DVFS)，对接外部 PMIC 芯片。&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="170" x="550" y="590" as="geometry" />
        </mxCell>
        <mxCell id="2lWPLS22yn9Cp41EMGf9-14" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00897B;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #004D40;&quot;&gt;安全处理单元 (SPU)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #80CBC4; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #37474F;&quot;&gt;物理隔离的安全岛，存放指纹、面部加密密钥及执行高安全操作。&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="170" x="730" y="590" as="geometry" />
        </mxCell>
        <mxCell id="2lWPLS22yn9Cp41EMGf9-15" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00897B;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #004D40;&quot;&gt;传感器中枢 (Hub)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #80CBC4; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #37474F;&quot;&gt;超低功耗协同处理器，全天候不间断收集外部传感器数据以建立上下文。&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="170" x="910" y="590" as="geometry" />
        </mxCell>
        <mxCell id="2lWPLS22yn9Cp41EMGf9-16" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00897B;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #004D40;&quot;&gt;外设总线控制器&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #80CBC4; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #37474F;&quot;&gt;包含 I²C、SPI、UART、GPIO 等通用控制器的物理层与主控单元。&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="170" x="1090" y="590" as="geometry" />
        </mxCell>
        <mxCell id="2lWPLS22yn9Cp41EMGf9-17" edge="1" parent="1" source="2lWPLS22yn9Cp41EMGf9-5" style="edgeStyle=none;html=1;strokeWidth=3;strokeColor=#546E7A;endArrow=none;exitX=0.5;exitY=1;entryX=0.08;entryY=0;fontFamily=Comic Sans MS;" target="2lWPLS22yn9Cp41EMGf9-4">
