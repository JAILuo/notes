  <diagram id="7uCMT1gnnD9pZUzEbtpK" name="第 8 页">
    <mxGraphModel dx="1066" dy="614" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="Mz4qiJMaovWxtNlcfV9S-1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#90A4AE;strokeWidth=2.5;dashed=1;dashPattern=6 6;align=right;verticalAlign=bottom;spacing=15;fontColor=#78909C;fontSize=14;fontStyle=1;arcSize=2;fontFamily=Comic Sans MS;" value="SoC (System-on-Chip) 芯片整体封装边界 (Package)" vertex="1">
          <mxGeometry height="610" width="1110" x="170" y="230" as="geometry" />
        </mxCell>
        <mxCell id="Mz4qiJMaovWxtNlcfV9S-2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#78909C;strokeWidth=1.5;dashed=1;dashPattern=4 4;align=left;verticalAlign=bottom;spacing=15;fontColor=#546E7A;fontSize=13;fontStyle=1;arcSize=2;fontFamily=Comic Sans MS;" value="SoC Die (硅晶圆主芯片) 物理边界" vertex="1">
          <mxGeometry height="435" width="1070" x="180" y="365" as="geometry" />
        </mxCell>
        <mxCell id="Mz4qiJMaovWxtNlcfV9S-3" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 22px; color: rgb(44, 62, 80);&quot;&gt;通用片上系统 (SoC) 内部 IP 核内部 overview&lt;/b&gt;" vertex="1">
          <mxGeometry height="60" width="700" x="360" y="180" as="geometry" />
        </mxCell>
        <mxCell id="Mz4qiJMaovWxtNlcfV9S-4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#FF8F00;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=12;spacingRight=12;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #E65100;&quot;&gt;LPDDR 运行内存 (封装内独立 Die)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #FFE082; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #5D4037;&quot;&gt;采用封装级集成 (SiP/PoP)，作为独立 Die 封装于芯片内 (单片集成/eDRAM除外)。&lt;br&gt;物理上不属于 SoC 逻辑晶圆，通过高密度晶圆级微引脚与底层的存储物理层接口 (PHY) 实现对接。&lt;/span&gt;" vertex="1">
          <mxGeometry height="80" width="1030" x="200" y="255" as="geometry" />
        </mxCell>
        <mxCell id="Mz4qiJMaovWxtNlcfV9S-5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#37474F;strokeColor=none;fontColor=#ECEFF1;shadow=1;arcSize=10;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size:20px;letter-spacing:10px;&quot;&gt;片 内 互 联 总 线 &amp;nbsp; (System Interconnect Bus)&lt;/b&gt;" vertex="1">
          <mxGeometry height="45" width="1030" x="200" y="545" as="geometry" />
        </mxCell>
        <mxCell id="Mz4qiJMaovWxtNlcfV9S-6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0288D1;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=8;spacingRight=8;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #01579B;&quot;&gt;内存控制器&lt;br&gt;(DMC+PHY)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #81D4FA; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 10.5px; color: #455A64;&quot;&gt;作为 AXI Slave 接收片内请求，转换为 DDR 物理时序协议对接外部内存。&lt;/span&gt;" vertex="1">
          <mxGeometry height="120" width="125" x="200" y="395" as="geometry" />
        </mxCell>
        <mxCell id="Mz4qiJMaovWxtNlcfV9S-7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0288D1;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=8;spacingRight=8;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #01579B;&quot;&gt;应用处理器&lt;br&gt;(AP/CPU)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #81D4FA; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 10.5px; color: #455A64;&quot;&gt;多核高性能处理器，负责运行通用操作系统(HLOS)及核心事务调度。&lt;/span&gt;" vertex="1">
          <mxGeometry height="120" width="125" x="340" y="395" as="geometry" />
        </mxCell>
        <mxCell id="Mz4qiJMaovWxtNlcfV9S-8" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0288D1;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=8;spacingRight=8;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #01579B;&quot;&gt;图形处理器&lt;br&gt;(GPU)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #81D4FA; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 10.5px; color: #455A64;&quot;&gt;负责3D图形物理渲染生成画面，及通用 GPU 硬件并行计算加速(GPGPU)。&lt;/span&gt;" vertex="1">
          <mxGeometry height="120" width="125" x="480" y="395" as="geometry" />
        </mxCell>
        <mxCell id="Mz4qiJMaovWxtNlcfV9S-9" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0288D1;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=8;spacingRight=8;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #01579B;&quot;&gt;显示处理器&lt;br&gt;(DPU)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #81D4FA; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 10.5px; color: #455A64;&quot;&gt;负责2D图层合成、色彩转换，并驱动 MIPI DSI 接口直连屏幕，卸载 GPU 功耗。&lt;/span&gt;" vertex="1">
          <mxGeometry height="120" width="125" x="620" y="395" as="geometry" />
        </mxCell>
        <mxCell id="Mz4qiJMaovWxtNlcfV9S-10" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0288D1;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=8;spacingRight=8;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #01579B;&quot;&gt;图像处理器&lt;br&gt;(ISP)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #81D4FA; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 10.5px; color: #455A64;&quot;&gt;硬件级处理相机传感器 RAW 流，执行实时降噪、HDR 与色彩重构。&lt;/span&gt;" vertex="1">
          <mxGeometry height="120" width="125" x="760" y="395" as="geometry" />
        </mxCell>
        <mxCell id="Mz4qiJMaovWxtNlcfV9S-12" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#388E3C;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=8;spacingRight=8;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #1B5E20;&quot;&gt;蓝牙 / WiFi&lt;br&gt;协议栈&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #A5D6A7; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 10.5px; color: #2E7D32;&quot;&gt;处理无线连接的基带与协议层逻辑，对接外部射频前端天线模组。&lt;/span&gt;" vertex="1">
          <mxGeometry height="120" width="125" x="1060" y="395" as="geometry" />
        </mxCell>
        <mxCell id="Mz4qiJMaovWxtNlcfV9S-15" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00897B;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: rgb(0, 77, 64);&quot;&gt;电源控制逻辑&lt;/b&gt;&lt;hr style=&quot;border: 1px solid rgb(128, 203, 196); margin: 4px 0px;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: rgb(55, 71, 79);&quot;&gt;SoC 内部的分区电压与频率动态管理逻辑，对接外部主板 PMIC 芯片。&lt;/span&gt;" vertex="1">
          <mxGeometry height="120" width="145" x="528" y="625" as="geometry" />
        </mxCell>
        <mxCell id="Mz4qiJMaovWxtNlcfV9S-16" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00897B;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #004D40;&quot;&gt;安全处理单元 (SPU)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #80CBC4; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #37474F;&quot;&gt;硬件物理隔离安全岛，负责系统底层国密/RSA加解密及安全启动。&lt;/span&gt;" vertex="1">
          <mxGeometry height="120" width="145" x="692" y="625" as="geometry" />
        </mxCell>
        <mxCell id="Mz4qiJMaovWxtNlcfV9S-17" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00897B;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #004D40;&quot;&gt;低功耗 SensorHub&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #80CBC4; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #37474F;&quot;&gt;全天候不间断工作的微控制核心，独立聚合各类低速传感器上下文。&lt;/span&gt;" vertex="1">
          <mxGeometry height="120" width="145" x="856" y="625" as="geometry" />
        </mxCell>
        <mxCell id="Mz4qiJMaovWxtNlcfV9S-18" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00897B;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #004D40;&quot;&gt;外设总线主控&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #80CBC4; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #37474F;&quot;&gt;包含 I²C, SPI, UART, GPIO 等低速通信协议的硬件主控与 PHY 层。&lt;/span&gt;" vertex="1">
          <mxGeometry height="120" width="145" x="1020" y="625" as="geometry" />
