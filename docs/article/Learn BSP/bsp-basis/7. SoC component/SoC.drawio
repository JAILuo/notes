  <diagram name="SoC Architecture Overview" id="Hs0m71HMqD81ckrxn8jz">
    <mxGraphModel dx="1120" dy="851" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="GXNeeFGbuaCHAHwLssQV-1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;horizontal=0;fontStyle=1;fontSize=18;fontColor=#333333;" value="Interconnect bus" vertex="1">
          <mxGeometry height="850" width="60" x="450" y="360" as="geometry" />
        </mxCell>
        <mxCell id="GXNeeFGbuaCHAHwLssQV-2" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" value="&lt;b style=&quot;font-size: 14px;&quot;&gt;Figure 2/3-1: A high level view of a typical System-on-Chip (SoC)&lt;/b&gt;&lt;br&gt;&lt;br&gt;At a high level, an SoC is a collection of Intellectual&lt;br&gt;Property (IP) cores connected by an interconnect bus." vertex="1">
          <mxGeometry height="60" width="440" x="690" y="210" as="geometry" />
        </mxCell>
        <mxCell id="GXNeeFGbuaCHAHwLssQV-3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;align=center;verticalAlign=top;spacingTop=5;spacingLeft=5;spacingRight=5;" value="&lt;b style=&quot;font-size:14px;&quot;&gt;NPU/AI&lt;/b&gt;&lt;hr&gt;&lt;span style=&quot;font-size: 11px;&quot;&gt;2019+ chipsets often include a &quot;Neural Processing Unit&quot; to emulate neural networks&lt;/span&gt;" vertex="1">
          <mxGeometry height="80" width="240" x="150" y="410" as="geometry" />
        </mxCell>
        <mxCell id="GXNeeFGbuaCHAHwLssQV-4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;align=center;verticalAlign=top;spacingTop=5;spacingLeft=5;spacingRight=5;" value="&lt;b style=&quot;font-size:14px;&quot;&gt;TPU&lt;/b&gt;&lt;hr&gt;&lt;span style=&quot;font-size: 11px;&quot;&gt;Tensor operations (needed for AI) may be carried out by compute DSP or dedicated Tensor Processing Unit&lt;/span&gt;" vertex="1">
          <mxGeometry height="80" width="240" x="150" y="530" as="geometry" />
        </mxCell>
        <mxCell id="GXNeeFGbuaCHAHwLssQV-5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;align=center;verticalAlign=top;spacingTop=5;spacingLeft=5;spacingRight=5;" value="&lt;b style=&quot;font-size:14px;&quot;&gt;PMIC&lt;/b&gt;&lt;hr&gt;&lt;span style=&quot;font-size: 11px;&quot;&gt;Power Management Integrated Circuit arbitrates power to components&lt;/span&gt;" vertex="1">
          <mxGeometry height="80" width="240" x="150" y="650" as="geometry" />
        </mxCell>
        <mxCell id="GXNeeFGbuaCHAHwLssQV-6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;align=center;verticalAlign=top;spacingTop=5;spacingLeft=5;spacingRight=5;" value="&lt;b style=&quot;font-size:14px;&quot;&gt;SPU&lt;/b&gt;&lt;hr&gt;&lt;span style=&quot;font-size: 11px;&quot;&gt;Secure Processing Unit handles cryptography and out-of-CPU security services&lt;/span&gt;" vertex="1">
          <mxGeometry height="80" width="240" x="150" y="770" as="geometry" />
        </mxCell>
        <mxCell id="GXNeeFGbuaCHAHwLssQV-7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;align=center;verticalAlign=top;spacingTop=5;spacingLeft=5;spacingRight=5;" value="&lt;b style=&quot;font-size:14px;&quot;&gt;Sensor Hub&lt;/b&gt;&lt;hr&gt;&lt;span style=&quot;font-size: 11px;&quot;&gt;Sensor Hub controls and aggregates data from accelerometer, gyro, etc. establishing device &quot;context&quot;&lt;/span&gt;" vertex="1">
          <mxGeometry height="80" width="240" x="150" y="890" as="geometry" />
        </mxCell>
        <mxCell id="GXNeeFGbuaCHAHwLssQV-8" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;align=center;verticalAlign=top;spacingTop=5;spacingLeft=5;spacingRight=5;" value="&lt;b style=&quot;font-size:14px;&quot;&gt;Peripherals&lt;/b&gt;&lt;hr&gt;&lt;span style=&quot;font-size: 11px;&quot;&gt;Numerous other peripherals may be connected via I²C and/or other means&lt;/span&gt;" vertex="1">
          <mxGeometry height="80" width="240" x="150" y="1010" as="geometry" />
        </mxCell>
        <mxCell id="GXNeeFGbuaCHAHwLssQV-9" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;fontColor=#333333;strokeColor=#d6b656;align=center;verticalAlign=top;spacingTop=5;spacingLeft=5;spacingRight=5;" value="&lt;b style=&quot;font-size:14px;&quot;&gt;RAM&lt;/b&gt;&lt;hr&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;RAM provides AP with memory and DMA from other processors&lt;/span&gt;" vertex="1">
          <mxGeometry height="70" width="160" x="570" y="360" as="geometry" />
        </mxCell>
        <mxCell id="GXNeeFGbuaCHAHwLssQV-10" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;fontColor=#333333;strokeColor=#d6b656;align=center;verticalAlign=top;spacingTop=5;spacingLeft=5;spacingRight=5;" value="&lt;b style=&quot;font-size:14px;&quot;&gt;NAND&lt;/b&gt;&lt;hr&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;Flash memory provides persistent (non volatile) memory&lt;/span&gt;" vertex="1">
          <mxGeometry height="70" width="160" x="750" y="360" as="geometry" />
        </mxCell>
        <mxCell id="GXNeeFGbuaCHAHwLssQV-11" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;align=center;verticalAlign=top;spacingTop=5;spacingLeft=5;spacingRight=5;" value="&lt;b style=&quot;font-size:14px;&quot;&gt;AP (CPU)&lt;/b&gt;&lt;hr&gt;&lt;span style=&quot;font-size: 11px;&quot;&gt;Application Processor is multicore CPU running &quot;High Level OS&quot; (HLOS), e.g. Android&lt;/span&gt;" vertex="1">
          <mxGeometry height="80" width="240" x="570" y="470" as="geometry" />
        </mxCell>
        <mxCell id="GXNeeFGbuaCHAHwLssQV-12" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;align=center;verticalAlign=top;spacingTop=5;spacingLeft=5;spacingRight=5;" value="&lt;b style=&quot;font-size:14px;&quot;&gt;GPU&lt;/b&gt;&lt;hr&gt;&lt;span style=&quot;font-size: 11px;&quot;&gt;Graphics Processing Unit handles screen graphics and hardware acceleration&lt;/span&gt;" vertex="1">
          <mxGeometry height="80" width="240" x="570" y="590" as="geometry" />
        </mxCell>
        <mxCell id="GXNeeFGbuaCHAHwLssQV-13" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;align=center;verticalAlign=top;spacingTop=5;spacingLeft=5;spacingRight=5;" value="&lt;b style=&quot;font-size:14px;&quot;&gt;DSP&lt;/b&gt;&lt;hr&gt;&lt;span style=&quot;font-size: 11px;&quot;&gt;Digital Signal Processor handles voice and audio codecs, may offload vector computations&lt;/span&gt;" vertex="1">
          <mxGeometry height="80" width="240" x="570" y="710" as="geometry" />
        </mxCell>
        <mxCell id="GXNeeFGbuaCHAHwLssQV-14" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;align=center;verticalAlign=top;spacingTop=5;spacingLeft=5;spacingRight=5;" value="&lt;b style=&quot;font-size:14px;&quot;&gt;ISP&lt;/b&gt;&lt;hr&gt;&lt;span style=&quot;font-size: 11px;&quot;&gt;Image Signal Processor handles large megapixel photos, face detection&lt;/span&gt;" vertex="1">
          <mxGeometry height="80" width="240" x="570" y="830" as="geometry" />
        </mxCell>
        <mxCell id="GXNeeFGbuaCHAHwLssQV-15" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;align=center;verticalAlign=top;spacingTop=5;spacingLeft=5;spacingRight=5;" value="&lt;b style=&quot;font-size:14px;&quot;&gt;BT/WiFi&lt;/b&gt;&lt;hr&gt;&lt;span style=&quot;font-size: 11px;&quot;&gt;WiFi chipset handles 802.11 connectivity and often also includes BlueTooth&lt;/span&gt;" vertex="1">
          <mxGeometry height="80" width="240" x="570" y="950" as="geometry" />
        </mxCell>
        <mxCell id="GXNeeFGbuaCHAHwLssQV-16" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;align=center;verticalAlign=top;spacingTop=5;spacingLeft=5;spacingRight=5;" value="&lt;b style=&quot;font-size:14px;&quot;&gt;Baseband&lt;/b&gt;&lt;hr&gt;&lt;span style=&quot;font-size: 11px;&quot;&gt;Baseband (modem) provides cell connectivity (outside WiFi only devices)&lt;/span&gt;" vertex="1">
          <mxGeometry height="80" width="240" x="570" y="1070" as="geometry" />
        </mxCell>
