  <diagram id="Ms3IdlImSg-Y3wOx61D6" name="第 5 页">
    <mxGraphModel dx="1128" dy="651" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="W6PaB_jN0Ac-A0Uw5HY8-22" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#607D8B;strokeWidth=2.5;dashed=1;dashPattern=8 8;align=right;verticalAlign=bottom;spacing=20;fontColor=#455A64;fontSize=15;fontStyle=1;arcSize=1;fontFamily=Comic Sans MS;" value="高端智能手机双面多层高密度主板 (PCB 实际原理图拓扑演进)" vertex="1">
          <mxGeometry height="835" width="1340" x="727" y="750" as="geometry" />
        </mxCell>
        <mxCell id="W6PaB_jN0Ac-A0Uw5HY8-23" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 24px; color: rgb(26, 37, 44);&quot;&gt;智能手机系统级主板架构与外设全景连接拓扑&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size: 13px; color: rgb(84, 110, 122);&quot;&gt;参考高通 QRD、联发科参考设计及量产旗舰机维修原理图重构。明确各离散子系统、射频链路及双供电架构的物理协议总线互连。&lt;/span&gt;" vertex="1">
          <mxGeometry height="60" width="700" x="1051" y="790" as="geometry" />
        </mxCell>
        <mxCell id="W6PaB_jN0Ac-A0Uw5HY8-24" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#212121;strokeColor=#0D47A1;strokeWidth=3;shadow=1;arcSize=4;spacingTop=6;spacingLeft=12;spacingRight=12;verticalAlign=top;align=center;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 18px; color: #FFFFFF;&quot;&gt;中央主控 SoC 核心芯片&lt;/b&gt;&lt;br&gt;&lt;b style=&quot;font-size: 13px; color: #CFD8DC;&quot;&gt;(内置 AP应用核 + 5G基带Modem)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #455A64; margin: 6px 0;&quot;&gt;&lt;span style=&quot;font-size: 12px; color: #ECEFF1;&quot;&gt;系统绝对核心。集成多核CPU/GPU/NPU、射频基带逻辑、相机编解码器及各类标准高速外设控制器 PHY。&lt;/span&gt;" vertex="1">
          <mxGeometry height="120" width="320" x="1241" y="1085" as="geometry" />
        </mxCell>
        <mxCell id="W6PaB_jN0Ac-A0Uw5HY8-25" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#FF8F00;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: rgb(230, 81, 0);&quot;&gt;LPDDR5/5X 运行内存颗粒&lt;/b&gt;&lt;hr style=&quot;border: 1px solid rgb(255, 224, 130); margin: 4px 0px;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: rgb(93, 64, 55);&quot;&gt;通过 PoP 3D /SiP 封装和 SoC 连接，一般就在 SoC 头顶或在旁边紧密排布，走极短距离线宽。&lt;/span&gt;" vertex="1">
          <mxGeometry height="95" width="240" x="1110" y="890" as="geometry" />
        </mxCell>
        <mxCell id="W6PaB_jN0Ac-A0Uw5HY8-26" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#FF8F00;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #E65100;&quot;&gt;UFS 4.0 闪存芯片 (NAND)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #FFE082; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #5D4037;&quot;&gt;独立于 SoC 的大容量离散存储颗粒，存放系统固件、APP 与用户数据。&lt;/span&gt;" vertex="1">
          <mxGeometry height="95" width="240" x="1450" y="890" as="geometry" />
        </mxCell>
        <mxCell id="W6PaB_jN0Ac-A0Uw5HY8-27" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0288D1;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #01579B;&quot;&gt;多摄图像模组 (CMOS Sensor)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #81D4FA; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #455A64;&quot;&gt;主摄/超广角/长焦多感光元件，含 OIS 光学防抖及马达控制。&lt;/span&gt;" vertex="1">
          <mxGeometry height="95" width="240" x="780" y="890" as="geometry" />
        </mxCell>
        <mxCell id="W6PaB_jN0Ac-A0Uw5HY8-28" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0288D1;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #01579B;&quot;&gt;OLED 高刷显示屏 &amp;amp; 触控&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #81D4FA; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #455A64;&quot;&gt;高刷屏幕面板，集成独立 Touch 触控 IC、指纹透光区。&lt;/span&gt;" vertex="1">
          <mxGeometry height="95" width="240" x="780" y="1020" as="geometry" />
        </mxCell>
        <mxCell id="W6PaB_jN0Ac-A0Uw5HY8-29" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0288D1;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #01579B;&quot;&gt;超声波指纹 &amp;amp; 独立安全芯片&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #81D4FA; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #455A64;&quot;&gt;屏下指纹识别传感器 + 独立安全元件(eSE)，用于存储金融级支付密钥。&lt;/span&gt;" vertex="1">
          <mxGeometry height="95" width="240" x="780" y="1150" as="geometry" />
        </mxCell>
        <mxCell id="W6PaB_jN0Ac-A0Uw5HY8-30" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#388E3C;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #1B5E20;&quot;&gt;Wi-Fi 7 / 蓝牙 / GPS / NFC 芯片&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #A5D6A7; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #2E7D32;&quot;&gt;主板独立无线无线复合芯片（如高通WCN系列）。单独控制无线协议，配有高频多合一天线。&lt;/span&gt;" vertex="1">
          <mxGeometry height="105" width="240" x="1780" y="890" as="geometry" />
        </mxCell>
        <mxCell id="W6PaB_jN0Ac-A0Uw5HY8-31" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#388E3C;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #1B5E20;&quot;&gt;5G 射频前端复杂子系统&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #A5D6A7; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #2E7D32;&quot;&gt;高度复杂的射频链路：包含射频收发器(Transceiver)、多频段PA功率放大器、分集接收(DRX)及MIMO天线调谐器。&lt;/span&gt;" vertex="1">
          <mxGeometry height="120" width="240" x="1780" y="1025" as="geometry" />
        </mxCell>
        <mxCell id="W6PaB_jN0Ac-A0Uw5HY8-32" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#388E3C;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #1B5E20;&quot;&gt;SIM 卡槽 &amp;amp; eSIM 贴片芯片&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #A5D6A7; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #2E7D32;&quot;&gt;外部物理双卡卡座，或板载嵌入式安全 eSIM 颗粒，直接与基带握手。&lt;/span&gt;" vertex="1">
          <mxGeometry height="85" width="240" x="1780" y="1175" as="geometry" />
        </mxCell>
        <mxCell id="W6PaB_jN0Ac-A0Uw5HY8-33" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00897B;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #004D40;&quot;&gt;音频 Codec &amp;amp; 智能功放&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #80CBC4; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #37474F;&quot;&gt;离散音频解码芯片及大功率 Smart PA，驱动立体声扬声器与降噪麦克风。&lt;/span&gt;" vertex="1">
          <mxGeometry height="95" width="240" x="780" y="1310" as="geometry" />
        </mxCell>
        <mxCell id="W6PaB_jN0Ac-A0Uw5HY8-53" edge="1" parent="1" source="W6PaB_jN0Ac-A0Uw5HY8-34" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontFamily=Comic Sans MS;" target="W6PaB_jN0Ac-A0Uw5HY8-35" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="W6PaB_jN0Ac-A0Uw5HY8-34" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00897B;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #004D40;&quot;&gt;主电源管理芯片 (PMIC)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #80CBC4; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #37474F;&quot;&gt;系统供电大脑。通过多路 Buck 降压与 LDO 线性稳压管理全板各芯片复杂的开机供电时序。&lt;/span&gt;" vertex="1">
          <mxGeometry height="95" width="240" x="1080" y="1310" as="geometry" />
        </mxCell>
        <mxCell id="W6PaB_jN0Ac-A0Uw5HY8-35" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00897B;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #004D40;&quot;&gt;独立电荷泵快充芯片&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #80CBC4; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #37474F;&quot;&gt;专门管理高压直充的离散芯片。与 USB-C 接口连接，并通过 I²C 总线与主 PMIC 及 SoC 动态协同。&lt;/span&gt;" vertex="1">
          <mxGeometry height="95" width="240" x="1380" y="1310" as="geometry" />
        </mxCell>
        <mxCell id="W6PaB_jN0Ac-A0Uw5HY8-36" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00897B;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #004D40;&quot;&gt;USB Type-C 接口 &amp;amp; CC控制器&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #80CBC4; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #37474F;&quot;&gt;物理输入接口。内置 PD 协议握手、超高速差分对，支持快充、数据传与 DisplayPort 投屏。&lt;/span&gt;" vertex="1">
          <mxGeometry height="95" width="240" x="1680" y="1310" as="geometry" />
        </mxCell>
        <mxCell id="W6PaB_jN0Ac-A0Uw5HY8-37" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00897B;strokeWidth=2;shadow=1;arcSize=4;spacingTop=6;spacingLeft=12;spacingRight=12;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #004D40;&quot;&gt;板载低速外设组 (低功耗传感器、振动马达、相机闪光灯、物理按键)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #80CBC4; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #37474F;&quot;&gt;包含主板底层的惯性测量单元（IMU 陀螺仪+加速度计）、X轴线性马达驱动电路、高电流LED闪光灯驱动和侧边物理按键的中断判定线路。&lt;/span&gt;" vertex="1">
          <mxGeometry height="85" width="540" x="1080" y="1480" as="geometry" />
        </mxCell>
        <mxCell id="W6PaB_jN0Ac-A0Uw5HY8-38" edge="1" parent="1" source="W6PaB_jN0Ac-A0Uw5HY8-25" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2.5;strokeColor=#D84315;fontColor=#D84315;labelBackgroundColor=#FFFFFF;fontSize=11;fontStyle=1;exitX=0.5;exitY=1;entryX=0.25;entryY=0;dashed=1;fontFamily=Comic Sans MS;" target="W6PaB_jN0Ac-A0Uw5HY8-24" value="DRAM 独立高频寻址并行通道">
