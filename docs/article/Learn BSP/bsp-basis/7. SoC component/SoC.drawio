        <mxCell id="L3vqry6cuXJ4YUd-MeIt-1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#B0BEC5;strokeWidth=2;dashed=1;dashPattern=8 8;align=right;verticalAlign=bottom;spacing=15;fontColor=#90A4AE;fontSize=14;fontStyle=1;arcSize=2;" value="&lt;font face=&quot;Comic Sans MS&quot;&gt;SoC (System-on-Chip) 芯片物理边界&lt;/font&gt;" vertex="1">
          <mxGeometry height="610" width="1160" x="110" y="120" as="geometry" />
        </mxCell>
        <mxCell id="L3vqry6cuXJ4YUd-MeIt-2" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 24px; color: rgb(44, 62, 80);&quot;&gt;片上系统 (SoC) high level架构&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size: 14px; color: rgb(127, 140, 141);&quot;&gt;通过中央互联总线 (Interconnect Bus) 连接各个 IP 核的典型硬件概览&lt;/span&gt;" vertex="1">
          <mxGeometry height="60" width="700" x="340" y="140" as="geometry" />
        </mxCell>
        <mxCell id="L3vqry6cuXJ4YUd-MeIt-3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#37474F;strokeColor=none;fontColor=#ECEFF1;shadow=1;arcSize=10;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size:20px;letter-spacing:10px;&quot;&gt;&lt;font&gt;互 联 总 线 &amp;nbsp; (Interconnect Bus)&lt;/font&gt;&lt;/b&gt;" vertex="1">
          <mxGeometry height="45" width="1080" x="150" y="500" as="geometry" />
        </mxCell>
        <mxCell id="L3vqry6cuXJ4YUd-MeIt-4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0288D1;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #01579B;&quot;&gt;应用处理器 (AP)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #81D4FA; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #455A64;&quot;&gt;多核 CPU，负责运行诸如 Android 等“高级操作系统 (HLOS)”。&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="170" x="150" y="350" as="geometry" />
        </mxCell>
        <mxCell id="L3vqry6cuXJ4YUd-MeIt-5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0288D1;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #01579B;&quot;&gt;图形处理器 (GPU)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #81D4FA; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #455A64;&quot;&gt;处理屏幕图像渲染任务，并提供系统级的硬件加速。&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="170" x="330" y="350" as="geometry" />
        </mxCell>
        <mxCell id="L3vqry6cuXJ4YUd-MeIt-6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0288D1;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #01579B;&quot;&gt;数字信号处理器 (DSP)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #81D4FA; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #455A64;&quot;&gt;处理语音和音频编解码，有时也用于卸载矢量计算任务。&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="170" x="510" y="350" as="geometry" />
        </mxCell>
        <mxCell id="L3vqry6cuXJ4YUd-MeIt-7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0288D1;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #01579B;&quot;&gt;图像信号处理器 (ISP)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #81D4FA; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #455A64;&quot;&gt;处理千万像素级的巨量照片数据，执行面部检测等计算。&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="170" x="690" y="350" as="geometry" />
        </mxCell>
        <mxCell id="L3vqry6cuXJ4YUd-MeIt-8" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#388E3C;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #1B5E20;&quot;&gt;蓝牙 / WiFi&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #A5D6A7; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #2E7D32;&quot;&gt;WiFi芯片组，处理 802.11 无线连接，通常也集成了蓝牙功能。&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="170" x="870" y="350" as="geometry" />
        </mxCell>
        <mxCell id="L3vqry6cuXJ4YUd-MeIt-9" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#388E3C;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #1B5E20;&quot;&gt;基带 (Modem)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #A5D6A7; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #2E7D32;&quot;&gt;调制解调器，为设备提供蜂窝网络连接（纯WiFi设备除外）。&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="170" x="1050" y="350" as="geometry" />
        </mxCell>
        <mxCell id="L3vqry6cuXJ4YUd-MeIt-10" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#FF8F00;strokeWidth=2;shadow=1;arcSize=6;spacing=2;verticalAlign=top;align=center;fontFamily=Comic Sans MS;" value="&lt;div style=&quot;text-align: center;&quot;&gt;&lt;b style=&quot;font-size: 14px; color: #E65100;&quot;&gt;运行内存&lt;br&gt;(RAM)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #FFE082; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 10px; color: #5D4037;&quot;&gt;提供AP内存及DMA访问&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="100" width="80" x="560" y="210" as="geometry" />
        </mxCell>
        <mxCell id="L3vqry6cuXJ4YUd-MeIt-11" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#FF8F00;strokeWidth=2;shadow=1;arcSize=6;spacing=2;verticalAlign=top;align=center;fontFamily=Comic Sans MS;" value="&lt;div style=&quot;text-align: center;&quot;&gt;&lt;b style=&quot;font-size: 14px; color: #E65100;&quot;&gt;闪存&lt;br&gt;(NAND)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #FFE082; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 10px; color: #5D4037;&quot;&gt;提供系统持久化(非易失)存储&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="100" width="80" x="730" y="210" as="geometry" />
        </mxCell>
        <mxCell id="L3vqry6cuXJ4YUd-MeIt-12" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0288D1;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #01579B;&quot;&gt;神经网络 / AI (NPU)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #81D4FA; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #455A64;&quot;&gt;2019年后的芯片常包含专用的神经网络处理单元，以模拟神经网络计算。&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="170" x="150" y="580" as="geometry" />
        </mxCell>
        <mxCell id="L3vqry6cuXJ4YUd-MeIt-13" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0288D1;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #01579B;&quot;&gt;张量处理器 (TPU)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #81D4FA; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #455A64;&quot;&gt;AI所需的张量运算可由特定的计算DSP完成，或由专用的TPU执行。&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="170" x="330" y="580" as="geometry" />
        </mxCell>
        <mxCell id="L3vqry6cuXJ4YUd-MeIt-14" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00897B;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #004D40;&quot;&gt;电源管理 (PMIC)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #80CBC4; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #37474F;&quot;&gt;电源管理集成电路，负责为系统内的各个组件仲裁和分配电力。&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="170" x="510" y="580" as="geometry" />
        </mxCell>
        <mxCell id="L3vqry6cuXJ4YUd-MeIt-15" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00897B;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #004D40;&quot;&gt;安全处理单元 (SPU)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #80CBC4; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #37474F;&quot;&gt;独立于主CPU之外，专门处理密码学运算并提供底层安全服务。&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="170" x="690" y="580" as="geometry" />
        </mxCell>
        <mxCell id="L3vqry6cuXJ4YUd-MeIt-16" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00897B;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: rgb(0, 77, 64);&quot;&gt;Sensor Hub&lt;/b&gt;&lt;hr style=&quot;border: 1px solid rgb(128, 203, 196); margin: 4px 0px;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: rgb(55, 71, 79);&quot;&gt;控制并聚合来自加速度计、陀螺仪等的数据，建立设备的“上下文”。&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="170" x="870" y="580" as="geometry" />
        </mxCell>
        <mxCell id="L3vqry6cuXJ4YUd-MeIt-17" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00897B;strokeWidth=2;shadow=1;arcSize=6;spacingTop=6;spacingLeft=10;spacingRight=10;verticalAlign=top;align=left;fontFamily=Comic Sans MS;" value="&lt;b style=&quot;font-size: 15px; color: #004D40;&quot;&gt;外设 (Peripherals)&lt;/b&gt;&lt;hr style=&quot;border: 1px solid #80CBC4; margin: 4px 0;&quot;&gt;&lt;span style=&quot;font-size: 11px; color: #37474F;&quot;&gt;各类其他外围设备，通常通过 I²C 协议或其它硬件接口接入系统。&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="170" x="1050" y="580" as="geometry" />
        </mxCell>
